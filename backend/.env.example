APP_ENV=development
DEBUG=true

# Development: SQLite (works out of the box, no Postgres needed)
DATABASE_URL=sqlite:///./shared_expenses.db

# Production: PostgreSQL (Neon, Render, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clerk authentication (optional in dev — set CLERK_ENABLED=false to use email login)
CLERK_ENABLED=false
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_JWKS_URL=https://api.clerk.com/v1/jwks
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev

JWT_SECRET_KEY=dev-secret-change-in-production-please-use-a-random-string
JWT_ALGORITHM=HS256

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

DEFAULT_CURRENCY=INR
SUPPORTED_CURRENCIES=INR,USD,EUR,GBP,JPY