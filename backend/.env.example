

# ----- Application -----
APP_ENV=development               # "development" or "production"
DEBUG=true                         # MUST be false in production

# ----- Database (REQUIRED) -----
# Development (SQLite, no setup needed):
DATABASE_URL=sqlite:///./shared_expenses.db
# Production (PostgreSQL — e.g. Neon free tier):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ----- Clerk Authentication (REQUIRED in production) -----
CLERK_ENABLED=false                # Set to true in production
CLERK_PUBLISHABLE_KEY=pk_test_xxx  # pk_live_xxx in production
CLERK_SECRET_KEY=sk_test_xxx       # sk_live_xxx in production (NEVER expose)
CLERK_JWKS_URL=https://api.clerk.com/v1/jwks
CLERK_ISSUER=https://your-app.clerk.accounts.dev

# ----- JWT (REQUIRED in production) -----
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256

# ----- CORS (REQUIRED in production) -----
# Comma-separated list of allowed origins
# Development: localhost URLs
# Production: your Vercel frontend URL (e.g. https://your-app.vercel.app)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ----- Currency -----
DEFAULT_CURRENCY=INR
SUPPORTED_CURRENCIES=INR,USD,EUR,GBP,JPY

# ----- CSV Import Limits -----
MAX_CSV_SIZE_MB=5
MAX_CSV_ROWS=1000
